RECOUP_API_KEY=
PAYMASTER_KEY=
RESOURCE_WALLET_ADDRESS=

# ── Tier 2: Feature-specific (won't block startup) ──
EVAL_ACCESS_TOKEN=
ARWEAVE_KEY=
APIFY_TOKEN=
RESEND_API_KEY=
PERPLEXITY_API_KEY=
SERPAPI_API_KEY=
ANTHROPIC_API_KEY=

